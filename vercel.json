{
  "version": 2,
  "builds": [
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/flights.html",
      "dest": "/frontend/flights.html"
    },
    {
      "src": "/passengers.html",
      "dest": "/frontend/passengers.html"
    },
    {
      "src": "/bookings.html",
      "dest": "/frontend/bookings.html"
    },
    {
      "src": "/search.html",
      "dest": "/frontend/search.html"
    },
    {
      "src": "/reports.html",
      "dest": "/frontend/reports.html"
    },
    {
      "src": "/ticket.html",
      "dest": "/frontend/ticket.html"
    },
    {
      "src": "/calendar.html",
      "dest": "/frontend/calendar.html"
    },
    {
      "src": "/tracking.html",
      "dest": "/frontend/tracking.html"
    },
    {
      "src": "/seatmap.html",
      "dest": "/frontend/seatmap.html"
    },
    {
      "src": "/history.html",
      "dest": "/frontend/history.html"
    },
    {
      "src": "/login.html",
      "dest": "/frontend/login.html"
    },
    {
      "src": "/css/(.*)",
      "dest": "/frontend/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/frontend/js/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ]
}